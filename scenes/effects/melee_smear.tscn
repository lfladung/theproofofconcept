[sub_resource type="Shader" id="1_crescent_shader"]
code = "shader_type spatial;\nrender_mode blend_add, unshaded, cull_disabled, fog_disabled;\n\nuniform vec4 outer_color : source_color = vec4(0.22, 0.62, 1.0, 1.0);\nuniform vec4 inner_color : source_color = vec4(0.56, 0.86, 1.0, 1.0);\nuniform float effect_alpha : hint_range(0.0, 1.0) = 0.0;\nuniform float alpha_multiplier : hint_range(0.0, 2.0) = 1.0;\nuniform float inner_radius : hint_range(0.0, 1.5) = 0.46;\nuniform float outer_radius : hint_range(0.0, 1.5) = 0.95;\nuniform float arc_start_deg : hint_range(-180.0, 180.0) = -148.0;\nuniform float arc_end_deg : hint_range(-180.0, 180.0) = 38.0;\nuniform float edge_softness : hint_range(0.001, 0.4) = 0.08;\nuniform float axis_squash : hint_range(0.2, 3.0) = 1.35;\nuniform float emission_strength : hint_range(0.0, 8.0) = 2.1;\n\nvoid fragment() {\n\tvec2 uv = UV * 2.0 - vec2(1.0);\n\tuv.y *= axis_squash;\n\tfloat radius = length(uv);\n\tfloat angle = degrees(atan(uv.y, uv.x));\n\tfloat arc_gate = smoothstep(arc_start_deg - 12.0, arc_start_deg + 8.0, angle) * (1.0 - smoothstep(arc_end_deg - 8.0, arc_end_deg + 12.0, angle));\n\tfloat outer_falloff = 1.0 - smoothstep(outer_radius - edge_softness, outer_radius + edge_softness, radius);\n\tfloat inner_falloff = smoothstep(inner_radius - edge_softness, inner_radius + edge_softness, radius);\n\tfloat radial_band = outer_falloff * inner_falloff;\n\tfloat forward_bias = smoothstep(-0.45, 0.85, uv.x);\n\tfloat blade_core = smoothstep(0.12, 0.88, forward_bias);\n\tfloat alpha = radial_band * arc_gate * mix(0.45, 1.0, forward_bias) * effect_alpha * alpha_multiplier;\n\tvec3 color = mix(outer_color.rgb, inner_color.rgb, blade_core);\n\tALBEDO = color;\n\tEMISSION = color * emission_strength * mix(0.9, 1.25, blade_core);\n\tALPHA = alpha;\n}\n"

